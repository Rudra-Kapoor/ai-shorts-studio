# Worker env for the LOCAL Docker stack.
# Copy this file to:  worker/.env.worker.local   and paste your Groq key below.
# The hostnames here are docker-network names (mongo, minio, ...) — leave them.

# >>> REQUIRED: your free Groq API key — https://console.groq.com -> API Keys
GROQ_API_KEY=
# Optional: Gemini key for auto captions/hashtags — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Local infrastructure (already wired to docker-compose; leave as-is) ---
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=ai_shorts
R2_ENDPOINT=http://minio:9000
R2_ACCESS_KEY_ID=localminio
R2_SECRET_ACCESS_KEY=localminio123
R2_BUCKET=ai-shorts
UPSTASH_REDIS_REST_URL=http://serverless-redis-http:80
UPSTASH_REDIS_REST_TOKEN=localdevtoken
WORKER_SECRET=localworkersecret

# Pipeline tuning (sensible defaults)
MAX_CLIPS=3
MIN_CLIP_SEC=15
MAX_CLIP_SEC=60
