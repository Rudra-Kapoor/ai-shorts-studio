# =====================================================================
# AI SHORTS STUDIO — MASTER ENV REFERENCE
# =====================================================================
# This file lists EVERY secret the project uses. You do NOT put real
# values here. Instead:
#   - Web (Vercel):   copy the WEB block into Vercel → Project → Settings → Environment Variables
#   - Worker (Render): copy the WORKER block into Render → Service → Environment
#
# All services below have a free tier. Nothing here costs money.
# ---------------------------------------------------------------------

# ============================== WEB (Vercel) =========================
# MongoDB Atlas — free 512MB cluster. Get from Atlas → Connect → Drivers.
MONGODB_URI="mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net"
MONGODB_DB="ai_shorts"
