# =====================================================================
# AI SHORTS STUDIO — MASTER ENV REFERENCE
# =====================================================================
# This file lists EVERY secret the project uses. You do NOT put real
# values here. Instead:
#   - Web (Vercel):   copy the WEB block into Vercel → Project → Settings → Environment Variables
#   - Worker (Render): copy the WORKER block into Render → Service → Environment
#
# All services below have a free tier. Nothing here costs money.
# ---------------------------------------------------------------------

# ============================== WEB (Vercel) =========================
# MongoDB Atlas — free 512MB cluster. Get from Atlas → Connect → Drivers.
MONGODB_URI="mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net"
MONGODB_DB="ai_shorts"

# Cloudflare R2 — free 10GB. Create an R2 bucket + API token (S3 creds).
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key"
R2_SECRET_ACCESS_KEY="your_r2_secret_key"
R2_BUCKET="ai-shorts"

# Upstash Redis — free serverless. Use the REST URL + token.
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# The deployed worker URL (Render). The web app pings this to "wake" it.
WORKER_URL="https://ai-shorts-worker.onrender.com"
# Shared secret so only your web app can wake/queue the worker.
WORKER_SECRET="make-up-a-long-random-string"

# Per-user daily video quota (protects the free AI tiers). Optional, default 10.
MAX_VIDEOS_PER_DAY="10"

# ============================== WORKER (Render) ======================
# Groq — free. https://console.groq.com  (Whisper + Llama)
GROQ_API_KEY="gsk_xxx"

# Google Gemini — free. https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIza_xxx"

# The worker needs the SAME Mongo, R2 and Redis credentials as the web app:
MONGODB_URI="mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net"
MONGODB_DB="ai_shorts"
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key"
R2_SECRET_ACCESS_KEY="your_r2_secret_key"
R2_BUCKET="ai-shorts"
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"
WORKER_SECRET="make-up-a-long-random-string"

# Tuning (optional — sensible defaults baked in)
MAX_CLIPS="3"
MIN_CLIP_SEC="15"
MAX_CLIP_SEC="60"

# --- Phase 2/3 toggles (all optional; safe defaults) ---
CAPTION_STYLE="hormozi"     # default style: hormozi | mrbeast | minimal | clean
ASPECT_RATIO="9:16"         # default output ratio: 9:16 | 1:1 | 16:9 (per-video override at upload)
THUMBNAILS="1"              # generate a thumbnail per clip
VISION_SCORING="0"          # 1 = Gemini-vision keyframe scoring (more API calls)
FACE_CROP="0"               # 1 = face-aware crop (needs opencv-python-headless installed)
CHUNK_SEC="600"             # long-video transcription chunk size (seconds)

# --- Phase 3 auto-post (all optional; leave blank to disable) ---
# YouTube Data API — OAuth "Desktop app" client + a refresh token you generate once.
YT_CLIENT_ID=""
YT_CLIENT_SECRET=""
YT_REFRESH_TOKEN=""
# Instagram Graph API — Business/Creator account id + long-lived token.
IG_USER_ID=""
IG_ACCESS_TOKEN=""
