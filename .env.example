# =====================================================================
# AI SHORTS STUDIO — MASTER ENV REFERENCE
# =====================================================================
# This file lists EVERY secret the project uses. You do NOT put real
# values here. Instead:
#   - Web (Vercel):   copy the WEB block into Vercel → Project → Settings → Environment Variables
#   - Worker (Render): copy the WORKER block into Render → Service → Environment
#
# All services below have a free tier. Nothing here costs money.
# ---------------------------------------------------------------------

# ============================== WEB (Vercel) =========================
# MongoDB Atlas — free 512MB cluster. Get from Atlas → Connect → Drivers.
MONGODB_URI="mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net"
MONGODB_DB="ai_shorts"

# Cloudflare R2 — free 10GB. Create an R2 bucket + API token (S3 creds).
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key"
R2_SECRET_ACCESS_KEY="your_r2_secret_key"
R2_BUCKET="ai-shorts"

# Upstash Redis — free serverless. Use the REST URL + token.
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# The deployed worker URL (Render). The web app pings this to "wake" it.
WORKER_URL="https://ai-shorts-worker.onrender.com"
# Shared secret so only your web app can wake/queue the worker.
WORKER_SECRET="make-up-a-long-random-string"

# Per-user daily video quota (protects the free AI tiers). Optional, default 10.
MAX_VIDEOS_PER_DAY="10"
