# Web env for LOCAL dev. Copy this file to:  web/.env.local   (no edits needed).
# These point at the Docker services running on localhost.

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=ai_shorts

R2_ENDPOINT=http://localhost:9000
R2_ACCOUNT_ID=local
R2_ACCESS_KEY_ID=localminio
R2_SECRET_ACCESS_KEY=localminio123
R2_BUCKET=ai-shorts

UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=localdevtoken

WORKER_URL=http://localhost:8000
WORKER_SECRET=localworkersecret

MAX_VIDEOS_PER_DAY=100
