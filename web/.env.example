# Web app (Vercel) environment variables.
# Copy these into Vercel → Settings → Environment Variables.
# See ../.env.example for the full annotated reference.

MONGODB_URI=
MONGODB_DB=ai_shorts

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ai-shorts

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

WORKER_URL=
WORKER_SECRET=

MAX_VIDEOS_PER_DAY=10
